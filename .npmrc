# Enforce the `engines` block in package.json (npm >= 11).
#
# Without this, npm 10 installs a WRONG tree silently: its arborist no-ops workspace
# dependency bumps, so a bumped dep stays at its old version under apps/web/node_modules
# and shadows the correctly-hoisted one. `npm ci` exits 0; only `npm ls` reveals the
# "invalid" marker. The visible symptom is a unit test failing on behavior the stale
# package predates — which looks exactly like a code regression, while CI (pinned to
# npm 11) is green. Fail the install instead.
engine-strict=true
