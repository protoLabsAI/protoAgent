{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/protoagent-server",
          "sidecar": true,
          "args": ["--headless", "--port", { "validator": "\\d+" }]
        }
      ]
    }
  ]
}
